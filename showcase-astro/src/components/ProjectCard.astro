---
import type { PortfolioProject } from "../types/project";

interface Props {
  project: PortfolioProject;
}

const { project } = Astro.props;
const { slug, title, summary, tags, githubUrl, liveUrl, coverImage } = project;
const techs = tags.length ? tags : ["project"];
---

<div
  class="group flex flex-col border border-border/80 rounded-xl overflow-hidden bg-card/40 hover:border-border transition-colors"
  data-project-card
  data-tags={tags.join(" ")}
>
  <div class="aspect-16/10 overflow-hidden bg-muted/50 shrink-0">
    <a
      href={`/projects/${slug}/`}
      class="block h-full focus:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
    >
      {
        coverImage ? (
          <img
            src={coverImage}
            alt=""
            class="w-full h-full object-cover"
            loading="lazy"
          />
        ) : (
          <div class="w-full h-full flex items-center justify-center text-muted-foreground text-xs">
            No preview
          </div>
        )
      }
    </a>
  </div>

  <div class="p-5 md:p-6 flex flex-col flex-1">
    <h3 class="font-display text-lg font-semibold mb-2 tracking-tight">
      <a
        href={`/projects/${slug}/`}
        class="hover:underline decoration-border underline-offset-4 text-foreground"
      >
        {title}
      </a>
    </h3>
    <p class="text-muted-foreground text-sm leading-relaxed flex-1 mb-4">
      {summary}
    </p>

    <div class="flex flex-wrap gap-1.5 mb-5">
      {
        techs.map((tech) => (
          <span class="text-[11px] uppercase tracking-wide text-muted-foreground border border-border/80 px-2 py-0.5 rounded">
            {tech}
          </span>
        ))
      }
    </div>

    <div class="flex flex-wrap gap-2 mt-auto">
      <a
        href={`/projects/${slug}/`}
        class="inline-flex items-center gap-1.5 rounded-md bg-primary text-primary-foreground text-sm font-medium px-3 py-1.5 hover:opacity-90"
      >
        Case study
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </a>
      {
        githubUrl && (
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 rounded-md border border-border text-sm px-3 py-1.5 hover:bg-muted/30"
          >
            Code
          </a>
        )
      }
      {
        liveUrl && (
          <a
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 rounded-md text-sm px-3 py-1.5 text-muted-foreground hover:text-foreground"
          >
            Live
          </a>
        )
      }
    </div>
  </div>
</div>
