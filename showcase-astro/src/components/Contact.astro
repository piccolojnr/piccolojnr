---
const email = "rahimdaud246@gmail.com";
---

<section id="contact" class="section-padding border-b border-border/60">
  <div class="container-narrow">
    <div class="max-w-2xl mb-14 md:mb-20">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight mb-4">
        Contact
      </h2>
      <p class="text-muted-foreground text-lg leading-relaxed">
        For collaborations, freelance work, or questions about a project —
        email is the best way to reach me. I also keep profiles updated on the
        networks below.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-stretch">
      <div class="lg:col-span-5 flex flex-col">
        <div
          class="border border-border/80 rounded-xl p-8 md:p-10 bg-card/50 h-full flex flex-col justify-between gap-8"
        >
          <div>
            <p
              class="text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-3"
            >
              Email
            </p>
            <p class="text-muted-foreground leading-relaxed">
              I read everything that lands here; replies are usually within a few
              days.
            </p>
          </div>
          <a
            href={`mailto:${email}`}
            class="group inline-flex items-center gap-3 rounded-md border border-border bg-background px-5 py-4 text-left transition-colors hover:border-foreground/20 hover:bg-muted/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
          >
            <span
              class="flex h-11 w-11 shrink-0 items-center justify-center rounded-md border border-border bg-muted/40 text-foreground"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
              </svg>
            </span>
            <span class="min-w-0 flex-1">
              <span class="block text-sm text-muted-foreground mb-0.5"
                >Write me</span
              >
              <span
                class="block font-medium text-foreground truncate sm:whitespace-normal sm:break-all"
                >{email}</span
              >
            </span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              class="shrink-0 text-muted-foreground group-hover:-translate-y-0.5 group-hover:translate-x-0.5 transition-transform"
              aria-hidden="true"
            >
              <path d="M7 7h10v10M7 17 17 7"></path>
            </svg>
          </a>
        </div>
      </div>

      <div
        class="lg:col-span-7 border border-border/80 rounded-xl overflow-hidden divide-y divide-border/80 bg-card/30"
      >
        <div class="p-6 md:p-8 flex gap-4">
          <div
            class="flex h-11 w-11 shrink-0 items-center justify-center rounded-md border border-border bg-muted/40"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              class="text-foreground"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path>
            </svg>
          </div>
          <div class="min-w-0 pt-0.5">
            <p
              class="text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-1"
            >
              Phone
            </p>
            <a
              href="tel:+233245388584"
              class="text-foreground hover:underline underline-offset-4 text-lg"
            >
              +233 (245) 388-584
            </a>
          </div>
        </div>

        <div class="p-6 md:p-8 flex gap-4">
          <div
            class="flex h-11 w-11 shrink-0 items-center justify-center rounded-md border border-border bg-muted/40"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              class="text-foreground"
            >
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <div class="min-w-0 pt-0.5">
            <p
              class="text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-1"
            >
              Location
            </p>
            <p class="text-foreground text-lg">Accra, Ghana</p>
          </div>
        </div>

        <div class="p-6 md:p-8">
          <p
            class="text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-5"
          >
            Elsewhere
          </p>
          <ul class="flex flex-col sm:flex-row sm:flex-wrap gap-3">
            <li>
              <a
                href="https://github.com/piccolojnr"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2.5 rounded-md border border-border px-4 py-2.5 text-sm font-medium text-foreground transition-colors hover:border-foreground/20 hover:bg-muted/30"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="text-muted-foreground"
                  aria-hidden="true"
                >
                  <path
                    d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                  ></path>
                </svg>
                GitHub
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  class="text-muted-foreground"
                  aria-hidden="true"
                >
                  <path d="M7 7h10v10M7 17 17 7"></path>
                </svg>
              </a>
            </li>
            <li>
              <a
                href="https://www.linkedin.com/in/rahim-daud-piccolo"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2.5 rounded-md border border-border px-4 py-2.5 text-sm font-medium text-foreground transition-colors hover:border-foreground/20 hover:bg-muted/30"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="text-muted-foreground"
                  aria-hidden="true"
                >
                  <path
