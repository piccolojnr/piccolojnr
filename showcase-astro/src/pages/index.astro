---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import ProjectsSection from "../components/ProjectsSection.astro";
import Contact from "../components/Contact.astro";
import { loadPortfolioData } from "../lib/data";
import {
  HOME_DOCUMENT_TITLE,
  SITE_DESCRIPTION,
  SITE_KEYWORDS,
  homeJsonLd,
} from "../lib/site";

const { projects } = loadPortfolioData();
const featured = projects
  .filter((p) => p.featured)
  .sort((a, b) => a.sortOrder - b.sortOrder)
  .slice(0, 6);

const siteHref = (Astro.site ?? new URL("http://localhost:4321")).href;
---

<Layout
  title={HOME_DOCUMENT_TITLE}
  description={SITE_DESCRIPTION}
  canonicalPath="/"
  keywords={SITE_KEYWORDS}
  jsonLd={homeJsonLd(siteHref)}
>
  <div class="min-h-screen bg-background">
    <Hero />
    <About />
    <ProjectsSection projects={featured} />
    <Contact />
  </div>
</Layout>
